LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback
# Optional. If unset, OAuth stores/loads tokens from ~/.config/linkedin-fastmcp/token.json.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_TOKEN_FILE=
# Optional. Example: urn:li:person:abc123. If unset, the server derives this from /v2/userinfo sub.
LINKEDIN_MEMBER_URN=
# Scopes: openid profile email = Sign In with LinkedIn (OpenID Connect)
#         r_profile_basicinfo  = basic profile read
#         w_member_social      = posts, comments, reactions, image uploads
#         r_events             = read organization events
#         rw_events            = create/modify organization events
#         r_verify             = member verification status (needs Verified on LinkedIn product)
LINKEDIN_SCOPES=openid profile email r_profile_basicinfo w_member_social r_events rw_events
LINKEDIN_API_VERSION=202602
